from nova_api_core.infra.db.mongo.mongo_database_manager import MongoDatabaseManager

def get_database_manager(config: AppConfig) -> MongoDatabaseManager:
    db_url = f"mongodb://{config.DB_USER}:{config.DB_PASSWORD}@{config.DB_HOST}:{config.DB_PORT}"
    
    return MongoDatabaseManager(
        database_url=db_url,
        database_name=config.DB_NAME,
        max_session_retries=config.DB_MAX_RETRIES,
        retry_delay_seconds=config.DB_RETRY_DELAY
    )